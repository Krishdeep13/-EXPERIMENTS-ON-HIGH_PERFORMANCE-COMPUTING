#include <stdio.h>
#include <pthread.h>
#include <unistd.h>
int x=2;
void *f1(void *arg){
x+=5;
sleep(2);
printf("VALUE OF X: %d",x);
return NULL;
}
void *f2(void *arg){
sleep(2);
printf("VALUE: %d",x);
return NULL;
}
int main(){
pthread_t t1,t2;
pthread_create(&t1,NULL,f1,NULL);
pthread_create(&t2,NULL,f2,NULL);
pthread_join(t1,NULL);
pthread_join(t2,NULL);
return 0;
}
