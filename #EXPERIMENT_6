#include <stdio.h>
#include <pthread.h>
#include <time.h>
#include <stdlib.h>
#include <unistd.h>
void *roll(){
int value=(rand()%6)+1;
int *result =malloc(sizeof(int));
*result=value;
sleep(2);
printf("THREAD RESULT: %d\n",value);
pthread_exit((void *) result);
}
int main(){
int *res;
srand(time(NULL));
pthread_t th;
if(pthread_create(&th,NULL,&roll,NULL)!=0){
return 1;
}
if(pthread_join(th,(void**) &res)!=0){
return 2;
}
printf("RESULT: %d\n",*res);
free(res);
return 0;
}
